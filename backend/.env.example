# ──────────────────────────────────────────────────────────────
# CoachX Media AI — Backend Environment Variables
# Copy this file to .env and fill in your real values.
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Async PostgreSQL URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/coachxmedia

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────
# Change this to a long random string in production!
SECRET_KEY=changeme-secret-key
ALGORITHM=HS256
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────
# Obtain from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── AWS / S3 Storage ─────────────────────────────────────────
# Leave empty to use local filesystem fallback in development
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=coachxmedia-uploads
# Set this to http://localhost:4566 when using LocalStack
S3_ENDPOINT_URL=

# ── Stripe ────────────────────────────────────────────────────
# Obtain from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the Pro plan (created in Stripe dashboard)
STRIPE_PRICE_ID_PRO=

# ── CORS ──────────────────────────────────────────────────────
# JSON list of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# ── Upload Limits ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

# ── Admin Bootstrap ───────────────────────────────────────────
# Set these to auto-create an initial admin account on first startup.
# Leave ADMIN_EMAIL empty to skip the bootstrap step entirely.
# If an account with this email already exists its role is promoted to
# "admin" but the password is NOT changed.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=Administrator

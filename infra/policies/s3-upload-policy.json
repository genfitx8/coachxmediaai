{
  "_comment": "Bucket names follow the pattern <app_name>-uploads-<environment> (e.g. coachxmedia-uploads-production). Update the ARNs below to match your deployment.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3MediaAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectAcl",
        "s3:PutObjectAcl"
      ],
      "Resource": "arn:aws:s3:::coachxmedia-uploads-production/*"
    },
    {
      "Sid": "AllowS3ListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::coachxmedia-uploads-production"
    }
  ]
}
